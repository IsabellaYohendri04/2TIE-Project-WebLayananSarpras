# ============================================================
# Konfigurasi MySQL untuk Laragon
# ============================================================
# 1. Buka Laragon → klik "Start All" (pastikan MySQL hijau)
# 2. Salin file ini menjadi .env di folder backend/
# 3. Laragon default: user root, password kosong
# 4. Jika pakai MySQL80 Windows (bukan Laragon), isi DB_PASSWORD
#
# Catatan: Laragon MySQL dan MySQL80 tidak boleh bentrok di port 3306.
# Stop salah satu service jika koneksi gagal.
# ============================================================

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sarpras_db

PORT=3001
JWT_SECRET=sarpras_jwt_secret
JWT_EXPIRES_IN=7d
